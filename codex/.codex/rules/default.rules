prefix_rule(pattern=["curl", "-L", "https://raw.githubusercontent.com/ibhagwan/fzf-lua/refs/heads/main/README.md"], decision="allow")
prefix_rule(pattern=["curl", "-L", "https://raw.githubusercontent.com/ibhagwan/fzf-lua/refs/heads/main/OPTIONS.md"], decision="allow")
prefix_rule(pattern=["curl", "-L", "https://raw.githubusercontent.com/folke/noice.nvim/refs/heads/main/README.md"], decision="allow")
prefix_rule(pattern=["./tools/unused_imports_rust.py", "-v"], decision="allow")
prefix_rule(pattern=["bazel", "--bazelrc=rs/tools/unused_imports_rust/config.bazelrc", "cquery"], decision="allow")
prefix_rule(pattern=["bazel", "query"], decision="allow")
prefix_rule(pattern=["/bin/zsh", "-lc", "bazel query --keep_going --noshow_progress --ui_event_filters=-info,-debug,-warning \"rdeps(filter('_release$', attr(generator_function, rust_image, //rs/engine/... union //rs/geodata/... union //rs/tools/...)), //rs/engine/service/back/auth:auth)\""], decision="allow")
prefix_rule(pattern=["/bin/zsh", "-lc", "bazel query --keep_going --noshow_progress --ui_event_filters=-info,-debug,-warning \"filter('_release$', attr(generator_function, rust_image, //rs/engine/... union //rs/geodata/... union //rs/tools/...))\""], decision="allow")
prefix_rule(pattern=["/bin/zsh", "-lc", "bazel query --keep_going --noshow_progress --ui_event_filters=-info,-debug,-warning \"filter('_service$', attr(generator_function, rust_image, //rs/engine/... union //rs/geodata/... union //rs/tools/...))\""], decision="allow")
prefix_rule(pattern=["bazel", "build"], decision="allow")
prefix_rule(pattern=["./tools/clippy.py"], decision="allow")
prefix_rule(pattern=["nc", "-vz", "127.0.0.1", "6018"], decision="allow")
prefix_rule(pattern=["nc", "-vz", "127.0.0.1"], decision="allow")
prefix_rule(pattern=["/bin/zsh", "-lc", "PGPASSWORD=password psql -h 127.0.0.1 -U postgres -d postgres -c \"insert into metadata_by_user_uid (uid, first_name, last_name, birth_year, created_at, updated_at) values (103569146994762, 'Codex', 'Tester', 1998, now(), now()) on conflict (uid) do update set first_name = excluded.first_name, last_name = excluded.last_name, birth_year = excluded.birth_year, created_at = excluded.created_at, updated_at = now();\""], decision="allow")
prefix_rule(pattern=["/bin/zsh", "-lc", "PGPASSWORD=password psql -h 127.0.0.1 -U postgres -d postgres -c \"select uid, first_name, last_name, birth_year, asked_for_deletion_at, banned_until from metadata_by_user_uid where uid = 103569146994762;\""], decision="allow")
prefix_rule(pattern=["grpcurl", "-plaintext"], decision="allow")
prefix_rule(pattern=["curl", "--http2-prior-knowledge"], decision="allow")
prefix_rule(pattern=["cargo", "flamegraph"], decision="allow")
prefix_rule(pattern=["docker", "compose"], decision="allow")
