[user]
	name = ae2rs
	email = lucasdc@amo.co
[core]
	pager = delta
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true
[merge]
	conflictStyle = zdiff3
[merge "ours"]
	driver = true
[pull]
	rebase = true
[filter "lfs"]
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
[init]
	defaultBranch = main
[feature]
	manyFiles = true
[scalar]
	repo = /Users/lucas/dotfiles
	repo = /Users/lucas/work/monorepo
[maintenance]
	repo = /Users/lucas/dotfiles
	repo = /Users/lucas/work/monorepo
